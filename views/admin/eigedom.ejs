<%- include('partials/atop', { tittel: 'Leilegheiter (Eigedom)' }) %>

<p class="admin-forklaring">Leilegheitene blir viste på <a href="/eigedom">eigedomssida</a>.
Tekst og kontaktinfo for sjølve sida endrar du under <a href="/admin/sider/eigedom">Sider → Eigedom</a>.</p>

<% content.properties.forEach((e, i) => { %>
<details class="admin-detalj">
  <summary><strong><%= e.title %></strong></summary>
  <form method="post" action="/admin/eigedom/lagre" class="admin-skjema">
    <input type="hidden" name="_csrf" value="<%= csrf %>" />
    <input type="hidden" name="index" value="<%= i %>" />
    <div class="felt"><label for="e-title-<%= i %>">Tittel (adresse, by)</label>
      <input id="e-title-<%= i %>" name="title" value="<%= e.title %>" required /></div>
    <div class="felt"><label for="e-image-<%= i %>">Bilete</label>
      <select id="e-image-<%= i %>" name="image">
        <option value="">(ikkje noko bilete)</option>
        <% for (const m of (content.media || [])) { %><option value="<%= m.id %>" <%= e.image === m.id ? 'selected' : '' %>><%= m.id %></option><% } %>
      </select></div>
    <button type="submit" class="knapp knapp-primar">Lagre</button>
  </form>
  <div class="admin-rad-handlingar">
    <form method="post" action="/admin/eigedom/slett" data-stadfest="Slette «<%= e.title %>»?"><input type="hidden" name="_csrf" value="<%= csrf %>" /><input type="hidden" name="index" value="<%= i %>" /><button class="knapp knapp-liten knapp-fare">Slett</button></form>
  </div>
</details>
<% }) %>

<h2>Legg til leilegheit</h2>
<form method="post" action="/admin/eigedom/lagre" class="admin-skjema">
  <input type="hidden" name="_csrf" value="<%= csrf %>" />
  <input type="hidden" name="index" value="-1" />
  <div class="felt"><label for="ne-title">Tittel</label><input id="ne-title" name="title" required /></div>
  <div class="felt"><label for="ne-image">Bilete</label>
    <select id="ne-image" name="image">
      <option value="">(ikkje noko bilete)</option>
      <% for (const m of (content.media || [])) { %><option value="<%= m.id %>"><%= m.id %></option><% } %>
    </select></div>
  <button type="submit" class="knapp knapp-primar">Legg til</button>
</form>

<%- include('partials/abot') %>

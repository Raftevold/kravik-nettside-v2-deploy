# Kopier til .env (lokalt) eller sett som miljøvariablar på Render.

# Offentleg adresse til sida (utan skråstrek til slutt) – brukt i sitemap, canonical og JSON-LD
SITE_URL=https://kravik-nettside.onrender.com

# Sesjonsnøkkel for admin-innlogging (lang, tilfeldig streng)
SESSION_SECRET=

# Admin-innlogging. Passordet ligg som bcrypt-hash i data/auth.json og kan
# endrast i admin. Alternativt kan du overstyre med ADMIN_PASSWORD_HASH,
# eller setje ADMIN_PASSWORD for å setje nytt passord ved oppstart.
ADMIN_USER=admin
# ADMIN_PASSWORD=
# ADMIN_PASSWORD_HASH=

# Varig lagring: admin-endringar blir committa til dette GitHub-repoet
# og henta ned att ved oppstart. Token treng berre "contents: read/write"
# på akkurat dette repoet (fine-grained personal access token).
GITHUB_TOKEN=
GITHUB_REPO=brukar/kravik-nettside
GITHUB_BRANCH=main

# Valfri e-postvarsling for kontaktskjemaet (meldingane er uansett i admin)
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# CONTACT_EMAIL=post@kravik.no
